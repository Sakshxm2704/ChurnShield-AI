# ================================================================
# CHURN INTELLIGENCE PLATFORM — ENVIRONMENT CONFIGURATION
# ================================================================
# Copy to .env and fill in your values.
# ⚠  NEVER commit .env to version control.
# ================================================================

# ── Application ──────────────────────────────────────────────────
APP_NAME=CHURNSHIELD AI
APP_ENV=development          # development | staging | production
APP_VERSION=1.0.0
DEBUG=true

# ── Security (REQUIRED — minimum 32 chars) ────────────────────────
SECRET_KEY=dYOUR_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (SQLite default — swap to postgres:// for prod) ──────
DATABASE_URL=sqlite:///./data/churn_platform.db
# DATABASE_URL=postgresql://user:password@host:5432/churn_platform

# ── API Server ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8501
FRONTEND_PORT=8501

# ── ML Thresholds ─────────────────────────────────────────────────
ML_HIGH_RISK_THRESHOLD=0.65
ML_MEDIUM_RISK_THRESHOLD=0.35

# ── Alert System ──────────────────────────────────────────────────
ALERT_HIGH_RISK_THRESHOLD=0.65
ALERT_MEDIUM_RISK_THRESHOLD=0.45
ALERT_INACTIVE_DAYS_TRIGGER=30
ALERT_EMAIL_RECIPIENT=alerts@yourcompany.com

# ── SMTP Email (required for alert emails) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@churnplatform.io

# ── Cache ─────────────────────────────────────────────────────────
CACHE_TTL_ANALYTICS=300
CACHE_TTL_SEGMENTS=600
CACHE_TTL_ML_META=1800
CACHE_MAX_SIZE=512

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Render.com deployment ─────────────────────────────────────────
# RENDER_EXTERNAL_URL is auto-set by Render; no need to configure.

# ── PostgreSQL (Docker Compose / production) ──────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=churn_platform
POSTGRES_USER=churn_user
POSTGRES_PASSWORD=churn_password
PGADMIN_EMAIL=admin@churnplatform.io
PGADMIN_PASSWORD=admin1234

# ── Groq AI (for universal industry predictions) ──────────────────
GROQ_API_KEY=# .env.example
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.1-8b-instant

# ── Custom Model Retraining ────────────────────────────────────────
ALLOW_CUSTOM_TRAINING=true
CUSTOM_DATA_DIR=./data/custom
